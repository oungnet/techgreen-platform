# App
NODE_ENV=development
PORT=3000
SESSION_SECRET=replace-with-a-strong-random-secret
SESSION_COOKIE_SAMESITE=lax
FRONTEND_ORIGINS=http://localhost:3000

# Database (MySQL)
DATABASE_URL=mysql://root:password@localhost:3306/techgreen

# OAuth providers
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
FACEBOOK_APP_ID=your-facebook-app-id
FACEBOOK_APP_SECRET=your-facebook-app-secret

# Thai Government Open Data (data.go.th)
DATA_GO_TH_API_KEY=your-data-go-th-api-key
# Optional override (defaults to https://api.data.go.th/open-data)
DATA_GO_TH_BASE_URL=https://api.data.go.th/open-data

# Optional: existing platform integration
OAUTH_SERVER_URL=
OWNER_OPEN_ID=
JWT_SECRET=
VITE_APP_ID=
VITE_API_BASE_URL=
BUILT_IN_FORGE_API_URL=
BUILT_IN_FORGE_API_KEY=
